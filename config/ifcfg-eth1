# /etc/sysconfig/network-scripts/ifcfg-eth1
# Zabbix Appliance - druhá síťová karta (host-only / internal network)
# Zkopíruj tento soubor do Zabbix Appliance:
#   /etc/sysconfig/network-scripts/ifcfg-eth1
# Poté restartuj síť: systemctl restart network
#   nebo: nmcli connection reload && nmcli connection up eth1

TYPE=Ethernet
PROXY_METHOD=none
BROWSER_ONLY=no
BOOTPROTO=static
DEFROUTE=no
IPV4_FAILURE_FATAL=no
IPV6INIT=no
NAME=eth1
DEVICE=eth1
ONBOOT=yes

# UPRAV IP adresu dle svého prostředí (musí být ve stejné podsíti jako Bastion)
IPADDR=192.168.56.10
NETMASK=255.255.255.0
# GATEWAY zde záměrně není – výchozí brána zůstává na eth0
